# Backend (Spring Boot)
# Local dev: http://localhost:9000
# Docker Compose (root): http://backend:9000
BACKEND_BASE_URL=http://localhost:9000
BACKEND_TIMEOUT=30.0

# Agent ports
SEARCH_AGENT_PORT=8001
STYLIST_AGENT_PORT=8002
ORDER_AGENT_PORT=8003

# Orchestrator
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_SEARCH_AGENT_CARD_URL=http://localhost:8001/.well-known/agent.json
ORCHESTRATOR_STYLIST_AGENT_CARD_URL=http://localhost:8002/.well-known/agent.json
ORCHESTRATOR_ORDER_AGENT_CARD_URL=http://localhost:8003/.well-known/agent.json
ORCHESTRATOR_MAX_CONVERSATION_HISTORY=20

# LLM (OpenRouter)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=arcee-ai/trinity-large-preview:free

# Logging
LOG_LEVEL=INFO
